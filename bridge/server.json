{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.postergully/finny-mcp",
  "description": "MCP server bridging Claude.ai/Desktop with self-hosted Hermes via OAuth 2.1.",
  "status": "active",
  "repository": {
    "url": "https://github.com/freema/hermes-mcp",
    "source": "github"
  },
  "version": "1.4.0",
  "websiteUrl": "https://hermes-mcp.cloud",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "hermes-mcp",
      "version": "1.4.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FINNY_UPSTREAM_URL",
          "description": "URL of your Hermes gateway",
          "default": "http://127.0.0.1:8642",
          "isRequired": true
        },
        {
          "name": "FINNY_UPSTREAM_TOKEN",
          "description": "Bearer token for Hermes gateway authentication",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "FINNY_MODEL",
          "description": "Model name for chat completions (e.g. 'hermes' or 'hermes/<agentId>')",
          "default": "hermes-agent",
          "isRequired": false
        },
        {
          "name": "FINNY_TIMEOUT_MS",
          "description": "Request timeout in milliseconds",
          "default": "120000",
          "isRequired": false
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/freema/hermes-mcp:1.4.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FINNY_UPSTREAM_URL",
          "description": "URL of your Hermes gateway",
          "default": "http://127.0.0.1:8642",
          "isRequired": true
        },
        {
          "name": "FINNY_UPSTREAM_TOKEN",
          "description": "Bearer token for Hermes gateway authentication",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "FINNY_MODEL",
          "description": "Model name for chat completions",
          "default": "hermes-agent",
          "isRequired": false
        }
      ]
    }
  ]
}
