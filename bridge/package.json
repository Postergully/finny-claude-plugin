{
  "name": "@postergully/lolly-mcp",
  "version": "0.4.0",
  "mcpName": "io.github.freema/openclaw-mcp",
  "description": "MCP bridge exposing Lolly (OpenClaw ERP agent) as 3 semantic tools with envelope-validated responses.",
  "author": {
    "name": "Postergully"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lolly-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "node scripts/inline-skills.mjs && node scripts/inline-bless-list.mjs",
    "pretest": "node scripts/inline-skills.mjs && node scripts/inline-bless-list.mjs",
    "pretest:run": "node scripts/inline-skills.mjs && node scripts/inline-bless-list.mjs",
    "pretypecheck": "node scripts/inline-skills.mjs && node scripts/inline-bless-list.mjs",
    "build": "tsup",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npm run lint:fix && npm run typecheck",
    "check:all": "npm run check && npm run test:run && npm run build",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:judge": "LOLLY_LIVE_JUDGE_LOOP=1 vitest run src/__tests__/judgeLoop.test.ts"
  },
  "keywords": [
    "mcp",
    "openclaw",
    "netsuite",
    "lolly",
    "claude"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "yargs": "^17.7.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "plugins"
  ],
  "homepage": "https://github.com/Postergully/lolly-claude-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/Postergully/lolly-claude-plugin.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
