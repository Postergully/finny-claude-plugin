# "production" or "staging"
DEPLOY_ENV=staging

# auth.staging.11mirror.com or auth.prod.11mirror.com
ZITADEL_DOMAIN=auth.staging.11mirror.com

# Generate: openssl rand -hex 16
ZITADEL_MASTERKEY=replace-with-32-char-hex-string

# Generate: openssl rand -hex 16
ZITADEL_DB_PASSWORD=replace-with-secure-password

# Initial admin user password (change after first login)
ZITADEL_ADMIN_PASSWORD=ReplaceMe123!
